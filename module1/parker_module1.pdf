   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "===== Five-Number Summary (No DC) =====\n",
      "Min: 1.0\n",
      "Q1: 2.6\n",
      "Median: 4.8\n",
      "Q3: 6.2\n",
      "Max: 12.4\n",
      "IQR: 3.5\n"
     ]
    },
    {
     "data": {
      "image/png": "",
