   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "CO2\n",
      "(1.986, 4.071]       5\n",
      "(4.071, 6.143]      14\n",
      "(6.143, 8.214]       7\n",
      "(8.214, 10.286]      6\n",
      "(10.286, 12.357]     0\n",
      "(12.357, 14.429]     0\n",
      "(14.429, 16.5]       3\n",
      "Name: count, dtype: int64\n",
      "Proprtions:\n",
      "CO2\n",
      "(1.986, 4.071]      0.142857\n",
      "(4.071, 6.143]      0.400000\n",
      "(6.143, 8.214]      0.200000\n",
      "(8.214, 10.286]     0.171429\n",
      "(10.286, 12.357]    0.000000\n",
      "(12.357, 14.429]    0.000000\n",
      "(14.429, 16.5]      0.085714\n",
      "Name: count, dtype: float64\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from math import ceil, log2\n",
    "\n",
    "df = pd.read_csv(\"./carbon_west.dat\", sep=\"\\s+\")\n",
    "\n",
    "# Frequencies for continuous variable via grouping values into intervals\n",
    "\n",
    "# Bins for continuous variable via Sturges' Rule: k = 1 + log2(n)\n",
    "k = ceil(1 + log2(df.shape[0]))\n",
    "\n",
    "# CO2 column\n",
    "x = df[\"CO2\"]\n",
    "# Create bins into discrete intervals (continuous -> discrete variable)\n",
    "bins = pd.cut(x, bins=k)\n",
    "\n",
    "# Frequency distribution\n",
    "freqs = bins.value_counts().sort_index()\n",
    "print(freqs)\n",
    "\n",
    "# Proportions (for kicks)\n",
    "print(f\"Proprtions:\\n{freqs/len(x)}\")\n",
    "\n",
    "# Plotting Histogram\n",
    "plt.hist(x, bins=k, edgecolor=\"black\")\n",
    "plt.xlabel(\"CO2 Emissions (per tons per capita)\")\n",
    "plt.ylabel(\"Frequency\")\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "`(b) Your answer goes here`"
